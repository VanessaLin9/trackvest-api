PORT=3000

# 可逗號分隔多個前端來源，會被 CORS 接受（需帶 credentials）
FRONTEND_URL=http://localhost:3001

# JWT — used to sign short-lived access tokens (cookie-based auth)
JWT_SECRET=change_me_in_prod
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# Cookie 行為；production 建議 COOKIE_SECURE=true 且 SAMESITE=strict/lax
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.example.com

# Password for the seeded demo user (only used by `pnpm prisma db seed`).
# Keep it simple in dev; override in any shared / staging environment.
DEMO_USER_PASSWORD=demo-password
