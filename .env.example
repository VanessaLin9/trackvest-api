PORT=3000

# 可逗號分隔多個前端來源，會被 CORS 接受（需帶 credentials）
FRONTEND_URL=http://localhost:3001

# JWT — used to sign short-lived access tokens (cookie-based auth)
JWT_SECRET=change_me_in_prod
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# Cookie 行為；production 建議 COOKIE_SECURE=true 且 SAMESITE=strict/lax
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.example.com

# Password for the dev seed demo user (`pnpm db:seed` / `pnpm db:seed:dev`).
# Local default is fine; override in shared environments.
DEMO_USER_PASSWORD=demo-password

# Required for production demo seed (`pnpm db:seed:prod-demo`).
# Must be a non-empty secret — there is no production default.
# DEMO_USER_PASSWORD=

# Required opt-in for production demo seed (`pnpm db:seed:prod-demo`).
# Does not affect dev seed (`pnpm db:seed` / `pnpm db:seed:dev`).
ALLOW_PRODUCTION_DEMO_SEED=

# FinMind — daily TW/US stock prices + TW split events (Bearer token from finmindtrade.com)
FIN_MIND_TOKEN=
# FINMIND_API_BASE_URL=https://api.finmindtrade.com/api/v4/data

# Taiwan price backfill cron: max ever-held assets per run (FinMind rate limit)
BACKFILL_MAX_ASSETS_PER_RUN=10

# Cron sync for market prices and corporate actions. Disabled by default.
# Set to true only when the API should run scheduled FinMind sync jobs.
ENABLE_SCHEDULED_JOBS=

# Required to run pnpm db:rehearsal — drops and recreates local trackvest_rehearsal only.
# Refused for non-localhost DATABASE_URL hosts.
ALLOW_REHEARSAL_DB_RECREATE=
